{
  "name": "unblock-pro",
  "version": "2.0.26",
  "versionSonic": "2.0.15",
  "description": "Обход блокировок Discord, YouTube и Telegram в России — автоматический DPI bypass для macOS и Windows",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "start:simulate-update": "cross-env UNBLOCKPRO_SIMULATE_UPDATE=1 electron .",
    "build": "node scripts/run-build.js",
    "build:mac": "node scripts/run-build.js --mac",
    "build:win": "node scripts/run-build.js --win",
    "build:all": "node scripts/run-build.js --mac --win",
    "download-binaries": "node scripts/download-binaries.js",
    "portable:test-replace": "powershell -ExecutionPolicy Bypass -File scripts/run-portable-test.ps1",
    "portable:test-update": "powershell -ExecutionPolicy Bypass -File scripts/test-portable-update.ps1"
  },
  "keywords": [
    "discord",
    "youtube",
    "telegram",
    "dpi",
    "bypass",
    "unblock",
    "zapret",
    "russia",
    "censorship",
    "proxy",
    "vpn-alternative",
    "anti-dpi",
    "discord-unblock",
    "youtube-unblock",
    "telegram-unblock"
  ],
  "author": "gagajo45 (fork), sonic (original)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagajo45/unblock-pro"
  },
  "upstreamRepository": {
    "type": "git",
    "url": "https://github.com/by-sonic/unblock-pro"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "electron-updater": "^6.7.3",
    "sudo-prompt": "^9.2.1",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.sonic.unblockpro",
    "productName": "UnblockPro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/${platform}",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/sonic-icon.icns",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "UnblockPro-sonic${env.VERSION_SONIC}-v${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "assets/sonic-icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "artifactName": "UnblockPro-sonic${env.VERSION_SONIC}-v${version}-win-setup.${ext}"
    },
    "portable": {
      "artifactName": "UnblockPro-sonic${env.VERSION_SONIC}-v${version}-win-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "gagajo45",
      "repo": "unblock-pro",
      "releaseType": "release"
    }
  }
}
